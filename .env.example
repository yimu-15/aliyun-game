# =============================================================================
# 世界杯冠军预测 Agent — 环境变量配置
# =============================================================================
# 复制此文件为 .env 并填入实际值

# 项目路径
PROJECT_ROOT=D:/aliyun-game
DATA_DIR=data

# 后端服务
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# 前端服务
STREAMLIT_PORT=8501

# 预测引擎
MONTE_CARLO_SIMULATIONS=10000
RANDOM_SEED=42

# 日志级别
LOG_LEVEL=INFO

# Kaggle (可选, 用于自动下载数据集)
# KAGGLE_USERNAME=
# KAGGLE_KEY=
